{
    "elements": [
        {
            "type": "ValidationTextBox",
            "name": "ClientID",
            "caption": "Client ID"
        },
        {
            "type": "ValidationTextBox",
            "name": "ClientSecret",
            "caption": "Client Secret"
        },
        {
            "type": "ValidationTextBox",
            "name": "Username",
            "caption": "Miele Username (Email)"
        },
        {
            "type": "PasswordTextBox",
            "name": "Password",
            "caption": "Miele Password"
        },
        {
            "type": "Select",
            "name": "Country",
            "caption": "Country",
            "options": [
                { "caption": "Deutschland", "value": "de-DE" },
                { "caption": "Österreich", "value": "de-AT" },
                { "caption": "Schweiz", "value": "de-CH" }
            ]
        },
        {
            "type": "NumberSpinner",
            "name": "UpdateInterval",
            "caption": "Update Interval (seconds)",
            "minimum": 30,
            "maximum": 3600
        }
    ],
    "actions": [
        {
            "type": "Button",
            "caption": "Test Connection",
            "onClick": "SM_TestConnection($id);"
        },
        {
            "type": "Button",
            "caption": "Force Update",
            "onClick": "SM_FetchData($id);"
        }
    ],
    "status": [
        { "code": 102, "icon": "active", "caption": "Active" },
        { "code": 200, "icon": "error", "caption": "Authentication failed" },
        { "code": 201, "icon": "error", "caption": "API Error" }
    ]
}
